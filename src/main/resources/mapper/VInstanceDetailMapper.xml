<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.clawboard.mapper.VInstanceDetailMapper">

    <!-- ===== 新增接口 ===== -->
    
    <!-- 获取机构列表（去重，排除 deleted 状态） -->
    <select id="selectDistinctOrgCodes" resultType="com.company.clawboard.dto.OrgOption">
        SELECT DISTINCT
            user_config_org_code AS orgCode,
            user_config_org_code AS orgName
        FROM v_instance_detail
        WHERE status != 'deleted'
          AND user_config_org_code IS NOT NULL
        ORDER BY orgCode
    </select>

    <!-- 根据机构代码查询用户列表（排除 deleted 状态） -->
    <select id="selectUsersByOrgCodes" resultType="com.company.clawboard.dto.UserOption">
        SELECT DISTINCT
            uid AS userId,
            user_config_name AS userName
        FROM v_instance_detail
        WHERE status != 'deleted'
          AND user_config_org_code IN
        <foreach collection="orgCodes" item="orgCode" open="(" separator="," close=")">
            #{orgCode}
        </foreach>
        ORDER BY userId
    </select>

    <!-- ===== 以下为原有方法，保留以兼容现有代码 ===== -->

    <!-- 查询所有运行中的实例 -->
    <select id="selectRunningInstances" resultType="java.util.Map">
        SELECT 
            uid,
            user_config_name,
            user_config_org_code
        FROM v_instance_detail
        WHERE status = 'running'
    </select>

    <!-- 根据 uid 查询实例状态 -->
    <select id="selectStatusByUid" resultType="java.lang.String">
        SELECT status
        FROM v_instance_detail
        WHERE uid = #{uid}
        LIMIT 1
    </select>

    <!-- 批量查询多个 uid 的实例状态 -->
    <select id="selectStatusByUids" resultType="java.util.Map">
        SELECT 
            uid,
            status
        FROM v_instance_detail
        WHERE uid IN
        <foreach collection="uids" item="uid" open="(" separator="," close=")">
            #{uid}
        </foreach>
    </select>

    <!-- 统计注册用户数 -->
    <select id="countRegisteredUsers" resultType="java.lang.Integer">
        SELECT COUNT(DISTINCT uid)
        FROM v_instance_detail
        WHERE status != 'deleted'
    </select>

    <!-- 统计 OpenClaw 实例总数量（排除 deleted） -->
    <select id="countInstanceTotal" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM v_instance_detail
        WHERE status != 'deleted'
    </select>

    <!-- 统计 OpenClaw 异常实例数量（排除 deleted 和 running） -->
    <select id="countInstanceAbnormal" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM v_instance_detail
        WHERE status NOT IN ('deleted', 'running')
    </select>

</mapper>
