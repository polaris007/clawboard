new Date(0);\n      return dateB - dateA;\n    }).slice(0, limit);\n\n    for (const item of sortedMessages) {\n      const parsed = await parseEmail(item.body);\n      results.push({\n        uid: item.attributes.uid,\n\n[206 more lines in file. Use offset=440 to continue.]"}],"isError":false,"timestamp":1775817859027}}
