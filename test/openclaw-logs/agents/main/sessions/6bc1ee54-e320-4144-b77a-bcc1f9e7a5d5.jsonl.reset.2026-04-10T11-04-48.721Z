5,\n    \"lastDeliveryStatus\": \"unknown\",\n    \"consecutiveErrors\": 2,\n    \"lastError\": \"Channel is required (no configured channels detected). Set delivery.channel explicitly or use a main session with a previous channel.\"\n  },\n  \"deleteAfterRun\": false\n}"}],"details":{"id":"8b7b52e4-3cb5-4ac7-8d95-4493b5cce81e","name":"ТБђТЪЦу┤ДТђЦжѓ«С╗Хт╣ХтЈЉжђЂжѓ«С╗ХжђџуЪЦ","enabled":true,"createdAtMs":1775805162893,"updatedAtMs":1775815557188,"schedule":{"kind":"every","everyMs":600000,"anchorMs":1775814523391},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"У»иСй┐уће imap-smtp-email ТіђУЃйуџё imap тіЪУЃйТБђТЪЦТѕЉуџёжѓ«у«▒сђѓждќтЁѕУјитЈќтйЊтЅЇтїЌС║гТЌХжЌ┤№╝їуёХтљјУ«Ау«Ќ 10 тѕєжњЪтЅЇуџёТЌХжЌ┤уѓ╣сђѓтЈфуГЏжђЅтЄ║ТћХтѕ░ТЌХжЌ┤тюеУ┐ЎСИфТЌХжЌ┤уѓ╣С╣Ітљјуџёжѓ«С╗Х№╝ѕСИЦТа╝тцДС║ј 10 тѕєжњЪтЅЇ№╝їСИЇтїЁТІгТГБтЦй 10 тѕєжњЪтЅЇуџёжѓ«С╗Х№╝Ѕсђѓ\n\nТЅЙтЄ║тЁХСИГТюЅТЌХжЌ┤жЎљтѕХсђЂуЅ╣тѕФу┤ДТђЦуџёжѓ«С╗Х№╝ѕтдѓТѕфТГбТЌЦТюЪСИ┤У┐ЉсђЂС╝џУ««тЇ│т░єт╝ђтДІсђЂжюђУдЂуФІтЇ│тцёуљєуџёС║ІжА╣уГЅ№╝Ѕсђѓ\n\nтдѓТъюТЅЙтѕ░у┤ДТђЦжѓ«С╗Х№╝їт░єУ┐ЎС║Џжѓ«С╗ХуџёСИ╗жбўтњїтЁ│жћ«С┐АТЂ»ТЋ┤уљєТѕљСИђт░Ђжѓ«С╗Х№╝їуёХтљјСй┐уће imap-smtp-email ТіђУЃйуџё smtp тіЪУЃйт░єУ┐Ўт░Ђжѓ«С╗ХтЈЉжђЂу╗ЎТѕЉУЄфти▒№╝ѕnwftool@sina.com№╝Ѕсђѓжѓ«С╗ХСИ╗жбўУ»итїЁтљФ'сђљу┤ДТђЦжѓ«С╗ХжђџуЪЦсђЉ'№╝їтєЁт«╣УдЂТИЁТЎ░тѕЌтЄ║Т»Јт░Ђу┤ДТђЦжѓ«С╗ХуџёСИ╗жбўсђЂтЈЉС╗ХС║║сђЂТћХтѕ░ТЌХжЌ┤тњїтЁ│жћ«С┐АТЂ»сђѓ\n\nтдѓТъютюеТюђУ┐Љ 10 тѕєжњЪтєЁТ▓АТюЅТћХтѕ░С╗╗СйЋжѓ«С╗Х№╝їТѕќУђЁТ▓АТюЅу┤ДТђЦжѓ«С╗Х№╝їС╣ЪУ»итЈЉжђЂСИђт░ЂжђџуЪЦжѓ«С╗ХУ»┤ТўјТГцТЃЁтєхсђѓ\n\nТ│еТёЈ№╝џУ»иуА«С┐ЮСй┐ућеТГБуА«уџёТЌХтї║№╝ѕAsia/Shanghai№╝ЅТЮЦУ«Ау«ЌТЌХжЌ┤уфЌтЈБсђѓ","timeoutSeconds":300},"delivery":{"mode":"chat","channel":"last","bestEffort":false},"state":{"nextRunAtMs":1775815667978,"lastRunAtMs":1775815067978,"lastRunStatus":"error","lastStatus":"error","lastDurationMs":103755,"lastDeliveryStatus":"unknown","consecutiveErrors":2,"lastError":"Channel is required (no configured channels detected). Set delivery.channel explicitly or use a main session with a previous channel